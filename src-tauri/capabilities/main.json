{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main",
  "description": "Main window capability. Restricts FS access to app config/data and future workspace roots while explicitly blocking common secret locations (SSH keys, cloud credentials, keychains, etc.).",
  "windows": ["main"],
  "permissions": [
    "core:app:default",
    "core:event:default",
    "core:window:default",
    "core:resources:default",
    "core:menu:default",
    "core:tray:default",
    "core:window:allow-set-title",

    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$APPCONFIG/**" },
        { "path": "$APPDATA/Oxcer/**" }
      ],
      "deny": [
        { "path": "$HOME/.ssh/**" },
        { "path": "$HOME/.aws/**" },
        { "path": "$HOME/Library/Keychains/**" },
        { "path": "$HOME/Library/Passwords/**" }
      ]
    }
  ]
}

